{
  "name": "@vulms/sdk",
  "version": "0.1.0-beta.2",
  "description": "TypeScript SDK for Virtual University LMS (VULMS) — fetch assignments, quizzes, GDBs, and lectures with smart caching and session management",
  "keywords": [
    "vulms",
    "virtual-university",
    "lms",
    "sdk",
    "assignments",
    "quizzes",
    "typescript",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/vulms-sdk"
  },
  "homepage": "https://github.com/your-org/vulms-sdk#readme",
  "bugs": {
    "url": "https://github.com/your-org/vulms-sdk/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/your-org"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"no lint configured\"",
    "prepack": "npm run build",
    "dev:login": "tsx playground/test-login.ts",
    "dev:courses": "tsx playground/test-courses.ts",
    "dev:assignments": "tsx playground/test-assignments.ts",
    "dev:quizzes": "tsx playground/test-quizzes.ts",
    "dev:gdb": "tsx playground/test-gdb.ts",
    "dev:lectures": "tsx playground/test-lectures.ts",
    "dev:activities": "tsx playground/test-activities.ts",
    "dev:telemetry": "tsx playground/collect-telemetry.ts",
    "dev:stress": "tsx playground/stress-test.ts",
    "dev:stress-ms": "tsx playground/multi-session-stress.ts",
    "dev:memory": "tsx playground/memory-trace-validation.ts",
    "dev:benchmark": "tsx playground/benchmark.ts",
    "dev:release-gate": "tsx playground/release-gate.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "axios-cookiejar-support": "^5.0.0",
    "cheerio": "^1.0.0",
    "playwright": "^1.60.0",
    "tough-cookie": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/tough-cookie": "^4.0.5",
    "dotenv": "^17.4.2",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
