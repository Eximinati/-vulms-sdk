// **************************************************************************
// JsonSerializableGenerator
// **************************************************************************

_Course _$CourseFromJson(Map<String, dynamic> json) =>
    _Course(code: json['code'] as String, title: json['title'] as String);

Map<String, dynamic> _$CourseToJson(_Course instance) => <String, dynamic>{
  'code': instance.code,
  'title': instance.title,
};
