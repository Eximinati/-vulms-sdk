// **************************************************************************
// JsonSerializableGenerator
// **************************************************************************

_Grade _$GradeFromJson(Map<String, dynamic> json) => _Grade(
  courseCode: json['courseCode'] as String,
  courseTitle: json['courseTitle'] as String,
  title: json['title'] as String,
  type: json['type'] as String?,
  totalMarks: (json['totalMarks'] as num?)?.toDouble(),
  obtainedMarks: (json['obtainedMarks'] as num?)?.toDouble(),
  percentage: json['percentage'] as String?,
  letterGrade: json['letterGrade'] as String?,
  datePosted: json['datePosted'] == null
      ? null
      : DateTime.parse(json['datePosted'] as String),
);

Map<String, dynamic> _$GradeToJson(_Grade instance) => <String, dynamic>{
  'courseCode': instance.courseCode,
  'courseTitle': instance.courseTitle,
  'title': instance.title,
  'type': instance.type,
  'totalMarks': instance.totalMarks,
  'obtainedMarks': instance.obtainedMarks,
  'percentage': instance.percentage,
  'letterGrade': instance.letterGrade,
  'datePosted': instance.datePosted?.toIso8601String(),
};
